pipeline {
    agent {
        label 'electronix'
    }

    stages {
        stage('Creating database') {
            steps {
                sh 'python3 scripts/create_db.py'
            }
        }
    } 

    post {
        success {
            echo "Database created successfully ✅"
        }

        failure {
            echo "Database creation failed ❌"
        }
    }
}